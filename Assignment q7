#include <stdio.h>

int main()
{
    int matrix1[5][5], matrix2[5][5], sum[5][5];
    int i, j;

    printf("Addition of Two 5x5 Matrices \n");

    
    printf("Enter elements of First Matrix (5x5):\n");
    for(i = 0; i < 5; i++)
    {
        for(j = 0; j < 5; j++)
        {
            scanf("%d", &matrix1[i][j]);
        }
    }

   
    printf("\nEnter elements of Second Matrix (5x5):\n");
    for(i = 0; i < 5; i++)
    {
        for(j = 0; j < 5; j++)
        {
            scanf("%d", &matrix2[i][j]);
        }
    }

    
    for(i = 0; i < 5; i++)
    {
        for(j = 0; j < 5; j++)
        {
            sum[i][j] = matrix1[i][j] + matrix2[i][j];
        }
    }

    
    printf("\nSum of the two matrices:\n");
    for(i = 0; i < 5; i++)
    {
        for(j = 0; j < 5; j++)
        {
            printf("%5d ", sum[i][j]);   
        }
        printf("\n");
    }

    return 0;
}